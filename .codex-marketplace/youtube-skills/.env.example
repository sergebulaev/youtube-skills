# -----------------------------------------------------------------
# All variables below are OPTIONAL.
# The skills work in draft-only mode with nothing set: they write
# titles, descriptions, hook scripts, thumbnail briefs, and community
# posts you copy into YouTube Studio yourself.
# Add a PUBLORA_API_KEY to let the skills upload and schedule the
# video you supply.
# -----------------------------------------------------------------

# Publora API key - sign up free at https://app.publora.com/signup
PUBLORA_API_KEY=sk_your_key_here

# YouTube channel connection ID (format: youtube-UCxxxxxxxxxxxxxxxxxxxxxx)
# Find this in the Publora dashboard: Channels then your YouTube channel.
# Copy the whole thing including the youtube- prefix.
YOUTUBE_PLATFORM_ID=youtube-your_channel_id_here

# -----------------------------------------------------------------
# Apify token (optional) - if you later wire a YouTube data actor,
# the planner and title skills can pull a channel's recent titles and
# stats instead of asking you to paste them. Without a token, the
# skills fall back to asking for the numbers.
#
# Sign up: https://console.apify.com/sign-up
# Token:   https://console.apify.com/settings/integrations
# -----------------------------------------------------------------
APIFY_TOKEN=apify_api_your_token_here

# -----------------------------------------------------------------
# Advanced (Tier 2): if you've built your own uploader with Claude Code
# or Codex (e.g. on the YouTube Data API), set this to the command the
# skills invoke on approval. Leave unset unless you have one working.
# -----------------------------------------------------------------
# YOUTUBE_SKILLS_CUSTOM_POSTER=python /path/to/my-uploader.py
